#!/usr/bin/env -S uv run python
# Copyright 2025-2026 Dimensional Inc.  Licensed Apache-2.0.
#
# Record a video of the unitree_g1_nav_mujoco_sim blueprint running,
# entirely headless.  Boots the sim, drives the robot through a few
# waypoints in the converted scene_209 ("hssd_house") map, and captures
# top-down frames each tick from an in-process MuJoCo renderer.  Frames
# are encoded to MP4 via ffmpeg.
#
# Usage:
#   ./bin/record-sim-video [--out PATH] [--fps N] [--secs N]
#
# Output defaults to ``/tmp/sim_video.mp4``.
"""Record a headless cross-wall sim run as an MP4."""

from __future__ import annotations

import argparse
from pathlib import Path
import shutil
import subprocess
import sys
import threading
import time

import lcm as lcmlib
import mujoco
import numpy as np
from PIL import Image

from dimos.core.coordination.module_coordinator import ModuleCoordinator
from dimos.msgs.geometry_msgs.PointStamped import PointStamped
from dimos.msgs.nav_msgs.Odometry import Odometry
from dimos.protocol.service.lcmservice import _DEFAULT_LCM_URL
from dimos.robot.unitree.g1.blueprints.navigation.unitree_g1_nav_mujoco_sim import (
    unitree_g1_nav_mujoco_sim,
)


_SCENE_XML = (
    Path(__file__).resolve().parents[1] / "data" / "hssd_house" / "scene_hssd_house.xml"
)

_WAYPOINTS = [
    (0.2, -3.2, "dining_room"),
    (-3.0, 2.3, "kitchen"),
    (5.9, 2.8, "living_room"),
    (1.2, 5.0, "hallway"),
]


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--out", type=Path, default=Path("/tmp/sim_video.mp4"))
    parser.add_argument("--fps", type=int, default=15, help="output video framerate")
    parser.add_argument(
        "--secs",
        type=int,
        default=180,
        help="max recording duration; the script also stops once the last waypoint is reached",
    )
    parser.add_argument("--width", type=int, default=640)
    parser.add_argument("--height", type=int, default=480)
    parser.add_argument(
        "--per-waypoint-timeout",
        type=float,
        default=120.0,
        help="give up on a waypoint after this many seconds and try the next",
    )
    args = parser.parse_args()

    if not _SCENE_XML.exists():
        print(f"missing scene XML: {_SCENE_XML}", file=sys.stderr)
        return 1
    if not shutil.which("ffmpeg"):
        print("ffmpeg not on PATH — install it (brew install ffmpeg)", file=sys.stderr)
        return 1

    # Boot the sim headless with cmd_vel-driven kinematic robot.
    blueprint = unitree_g1_nav_mujoco_sim.global_config(
        mujoco_headless=True,
        mujoco_kinematic_robot=True,
    )
    coordinator = ModuleCoordinator.build(blueprint)

    # In-process renderer.  Loads the same MJCF the sim subprocess loaded
    # so the camera reflects the world the planner sees.
    model = mujoco.MjModel.from_xml_path(str(_SCENE_XML))
    data = mujoco.MjData(model)
    mujoco.mj_forward(model, data)
    renderer = mujoco.Renderer(model, height=args.height, width=args.width)
    cam = mujoco.MjvCamera()

    # Latest robot pose (LCM-fed).
    lock = threading.Lock()
    pose = {"x": 1.2, "y": -1.0, "z": 0.8, "ts": time.time()}

    def _on_odom(_channel: str, payload: bytes) -> None:
        msg = Odometry.lcm_decode(payload)
        with lock:
            pose["x"] = float(msg.x)
            pose["y"] = float(msg.y)
            pose["z"] = float(msg.pose.position.z)
            pose["ts"] = time.time()

    lcm = lcmlib.LCM(_DEFAULT_LCM_URL)
    sub = lcm.subscribe("/odometry#nav_msgs.Odometry", _on_odom)
    stop = threading.Event()

    def _lcm_loop() -> None:
        while not stop.is_set():
            try:
                lcm.handle_timeout(100)
            except Exception:
                pass

    pump = threading.Thread(target=_lcm_loop, daemon=True)
    pump.start()

    # Wait for first odom, then warm up.
    deadline = time.monotonic() + 60
    while time.monotonic() < deadline:
        with lock:
            if pose["ts"] != 0 and time.time() - pose["ts"] < 5.0:
                break
        time.sleep(0.5)
    print("odom online; warming up 10s…", flush=True)
    time.sleep(10)

    frames_dir = Path("/tmp/sim_video_frames")
    if frames_dir.exists():
        shutil.rmtree(frames_dir)
    frames_dir.mkdir(parents=True)

    # Frame-capture thread.
    captured: list[Path] = []
    capture_period = 1.0 / args.fps

    # Fixed top-down camera framing the whole 13-room house.  Camera
    # framing chosen to cover y∈[-7, 25] (south of dining_room to north
    # of bedroom_4).  Projection scale is derived from the model's actual
    # vis.global_.fovy — the earlier ad-hoc heuristic was off by ~½ and
    # placed the marker in the wrong room.
    import math as _math
    cam.lookat[:] = (1.5, 9.5, 0.0)
    cam.distance = 40.0
    cam.azimuth = 90.0
    cam.elevation = -89.999
    _fovy_rad = _math.radians(model.vis.global_.fovy)
    _vis_h = 2.0 * cam.distance * _math.tan(_fovy_rad / 2.0)

    def _draw_robot_marker(arr: np.ndarray, x: float, y: float) -> None:
        h, w, _ = arr.shape
        px_per_m = h / _vis_h
        cx = w / 2 + (x - cam.lookat[0]) * px_per_m
        cy = h / 2 - (y - cam.lookat[1]) * px_per_m
        r = 6
        ix0, ix1 = max(0, int(cx - r)), min(w, int(cx + r))
        iy0, iy1 = max(0, int(cy - r)), min(h, int(cy + r))
        if ix0 < ix1 and iy0 < iy1:
            arr[iy0:iy1, ix0:ix1] = (255, 32, 32)

    # MuJoCo's offscreen GL context is thread-local (and on macOS the
    # OpenGL context belongs to whatever thread first opened it), so all
    # render calls have to live on the main thread.  Goal publication
    # happens on a small worker; the main thread does capture + arrival
    # polling.
    def _capture_one() -> None:
        with lock:
            px, py, _pz = pose["x"], pose["y"], pose["z"]
        renderer.update_scene(data, camera=cam)
        img = renderer.render().copy()
        _draw_robot_marker(img, px, py)
        f = frames_dir / f"frame_{len(captured):06d}.png"
        Image.fromarray(img).save(f)
        captured.append(f)

    next_capture = time.monotonic()
    overall_deadline = time.monotonic() + args.secs

    for gx, gy, label in _WAYPOINTS:
        if time.monotonic() >= overall_deadline:
            break
        with lock:
            sx, sy = pose["x"], pose["y"]
        print(
            f"=== {label}: goal ({gx}, {gy}) | robot ({sx:.2f}, {sy:.2f}) ===",
            flush=True,
        )
        lcm.publish(
            "/clicked_point#geometry_msgs.PointStamped",
            PointStamped(x=gx, y=gy, z=0.0, ts=time.time(), frame_id="map").lcm_encode(),
        )
        wp_deadline = time.monotonic() + args.per_waypoint_timeout
        while time.monotonic() < min(wp_deadline, overall_deadline):
            now = time.monotonic()
            if now >= next_capture:
                _capture_one()
                next_capture += capture_period
            with lock:
                cx, cy = pose["x"], pose["y"]
            if (cx - gx) ** 2 + (cy - gy) ** 2 <= 4.0:
                print(f"    {label} reached at ({cx:.2f}, {cy:.2f})", flush=True)
                break
            time.sleep(0.05)

    # Tail-capture: a couple of frames after the last waypoint so the
    # video doesn't cut mid-motion.
    tail_end = time.monotonic() + 1.0
    while time.monotonic() < tail_end:
        if time.monotonic() >= next_capture:
            _capture_one()
            next_capture += capture_period
        time.sleep(0.05)

    print(f"captured {len(captured)} frames in {frames_dir}; encoding…", flush=True)
    stop.set()
    pump.join(timeout=3)
    lcm.unsubscribe(sub)
    coordinator.stop()

    # Encode with ffmpeg.
    args.out.parent.mkdir(parents=True, exist_ok=True)
    if args.out.exists():
        args.out.unlink()
    cmd = [
        "ffmpeg",
        "-y",
        "-loglevel",
        "error",
        "-r",
        str(args.fps),
        "-i",
        str(frames_dir / "frame_%06d.png"),
        "-c:v",
        "libx264",
        "-pix_fmt",
        "yuv420p",
        "-preset",
        "fast",
        str(args.out),
    ]
    print("ffmpeg " + " ".join(cmd[3:]), flush=True)
    rc = subprocess.run(cmd, check=False).returncode
    if rc != 0:
        print(f"ffmpeg failed (rc={rc})", file=sys.stderr)
        return rc

    print(f"video: {args.out} ({args.out.stat().st_size / 1e6:.1f} MB)", flush=True)
    return 0


if __name__ == "__main__":
    sys.exit(main())
