#!/usr/bin/env bash
# Installed by harness install_hooks.py. Two responsibilities, in order:
#   1. Block bad pushes (non-fork remote, dev/main, bad branch prefix).
#   2. If a chained predecessor exists (e.g. the git-lfs hook that ships
#      with `git lfs install`), re-invoke it so its behavior is preserved.
#
# git invokes this hook with: <remote_name> <remote_url>
# stdin lines: <local_ref> <local_sha> <remote_ref> <remote_sha>

set -e

remote_url="$2"
case "$remote_url" in
  *feipeng1234/dimos*) ;;
  *)
    echo "BLOCKED: harness only allows push to feipeng1234/dimos fork (got: $remote_url)" >&2
    exit 1
    ;;
esac

# We need stdin twice (once for the case loop, once for the chained hook),
# so cache it.
stdin_cache="$(cat)"

while IFS= read -r line; do
  # local_ref local_sha remote_ref remote_sha
  remote_ref="$(printf '%s\n' "$line" | awk '{print $3}')"
  case "$remote_ref" in
    refs/heads/dev|refs/heads/main)
      echo "BLOCKED: cannot push directly to dev/main (target: $remote_ref)" >&2
      exit 1
      ;;
    refs/heads/feat/*|refs/heads/fix/*|refs/heads/refactor/*|refs/heads/docs/*|refs/heads/test/*|refs/heads/chore/*|refs/heads/perf/*)
      ;;
    refs/heads/*)
      echo "BLOCKED: branch name must start with feat/|fix/|refactor/|docs/|test/|chore/|perf/ (got: $remote_ref)" >&2
      exit 1
      ;;
    *)
      ;;
  esac
done <<< "$stdin_cache"

# Chain to the most recent harness backup if present (preserves git-lfs etc).
# Always resolve via git so we look in .git/hooks regardless of where the
# script lives (it's typically symlinked from .cursor/skills/.../hooks/).
git_common_dir="$(git rev-parse --git-common-dir 2>/dev/null || echo "")"
if [ -n "$git_common_dir" ]; then
  hooks_dir="$git_common_dir/hooks"
  chained="$(ls -1t "$hooks_dir"/pre-push.harness-backup-* 2>/dev/null | head -1 || true)"
  if [ -n "$chained" ] && [ -x "$chained" ]; then
    printf '%s\n' "$stdin_cache" | exec "$chained" "$@"
  fi
fi

exit 0
