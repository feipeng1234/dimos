# 复制成 .env 后再填值: cp .env.example .env

# ---- 必填 ----
# GitHub 个人访问令牌, 在 https://github.com/settings/tokens 生成 (经典 token 勾 repo 即可)
GITHUB_TOKEN=ghp_xxx

# 默认仓库, 飞书消息里没指定 /repo 时用这个, 格式 owner/repo
DEFAULT_REPO=feipeng1234/dimos

# ---- 可选 ----
# 飞书自建应用的 Encrypt Key (在飞书开放平台 -> 事件订阅 -> 加密策略 里填了才需要)
# 一旦在飞书后台设置了 Encrypt Key, 这里必须填一致, 否则签名会校验失败
FEISHU_ENCRYPT_KEY=

# 飞书 v1 事件用的 Verification Token (新版 v2 事件用签名, 一般不用填)
FEISHU_VERIFICATION_TOKEN=

# 创建 issue 时打的 label, 给 worker loop 识别用
ISSUE_LABEL=agent-todo

# 服务监听端口
PORT=8000
