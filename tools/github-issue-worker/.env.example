# 复制成 .env 后再填值: cp .env.example .env

# ==== 必填 ====

# 监听哪个仓库的 issue (owner/repo)。worker 只盯一个仓库, 简单可控。
WORKER_REPO=feipeng1234/dimos

# PR 的目标分支 (PR base)。dimos 一般是 dev。
WORKER_BASE_BRANCH=dev

# Worker 的工作区根目录, 仓库会被 clone 到 ${WORKER_WORKSPACE}/${repo_name}
WORKER_WORKSPACE=~/agent-workspace

# ==== AI 后端 ====

# 调哪个 AI agent 来写代码: claude | cursor-agent | codex | dry
# dry = 不真的调 AI, 只在工作区写一个 AGENT_RAN.txt, 用来端到端冒烟测
WORKER_AGENT=claude

# 可选: 完全覆盖 agent 命令模板。{prompt} 会被替换成完整的任务描述。
# 留空 = 用 WORKER_AGENT 对应的内置默认模板。
# 例子:
#   WORKER_AGENT_CMD=claude --dangerously-skip-permissions -p {prompt}
#   WORKER_AGENT_CMD=cursor-agent -p {prompt} --output-format text
WORKER_AGENT_CMD=

# Agent 单次执行最长时间 (秒)。超时会 SIGKILL, issue 标 agent-failed。
WORKER_AGENT_TIMEOUT=1800

# ==== 调度 ====

# 没活干时的轮询间隔 (秒)
WORKER_POLL_INTERVAL=60

# ==== Label 名 (一般不用改) ====
WORKER_LABEL_TODO=agent-todo
WORKER_LABEL_RUNNING=agent-running
WORKER_LABEL_DONE=agent-done
WORKER_LABEL_FAILED=agent-failed
WORKER_LABEL_HUMAN=agent-needs-human

# ==== Skill 路径 ====

# Worker 会把这个文件路径塞进 prompt, 让 agent 自己去读详细操作手册。
# 留空 = 不引用任何 skill, prompt 里只有 inline 规则。
WORKER_SKILL_PATH=.cursor/skills/github-issue-to-pr/SKILL.md
